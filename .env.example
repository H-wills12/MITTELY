# ============================================
# MITTELY - Environment Variables Template
# Copy this file to .env and add your actual values
# DO NOT commit .env to version control!
# ============================================

# ============================================
# APP CONFIGURATION
# ============================================

# App URL (your Netlify domain or custom domain)
APP_URL=https://your-site.netlify.app

# App Environment (development, staging, production)
NODE_ENV=production

# ============================================
# GOOGLE OAUTH 2.0
# ============================================

# Google OAuth Client ID (from Google Cloud Console)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# JWT AUTHENTICATION
# ============================================

# JWT Secret Key (generate a random 32+ character string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-random-32-char-secret-key-here

# ============================================
# ADMIN CONFIGURATION
# ============================================

# Admin Email Address (only this email can access admin panel)
ADMIN_EMAIL=henryagyemang906@gmail.com

# Admin Verification Code (for extra security)
ADMIN_VERIFICATION_CODE=KINGSMAN906@ML

# ============================================
# GMAIL SMTP (Free Email Service)
# ============================================

# Gmail App Password (16 characters with spaces)
# Get from: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# No-Reply Email Address (must be the same Gmail account)
NOREPLY_EMAIL=your-email@gmail.com

# Support Email Address
SUPPORT_EMAIL=your-email@gmail.com

# ============================================
# PAYSTACK PAYMENT GATEWAY
# ============================================

# Paystack Secret Key (Test Mode)
# Get from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paystack Public Key (Test Mode)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# HELEKET PAYMENT GATEWAY
# ============================================

# Heleket API Key
# Get from: Heleket Dashboard → Business Settings → API
HELEKET_API_KEY=your-heleket-api-key-here

# Heleket Domain Verification Meta Tag
# This is already added in all HTML files: <meta name="heleket" content="3bebdecb" />
HELEKET_DOMAIN_VERIFICATION=3bebdecb

# ============================================
# DATABASE (Optional - for production)
# ============================================

# Use Mock Database (true for development, false for production)
USE_MOCK_DB=true